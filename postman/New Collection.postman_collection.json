                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 200\", function () {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Token exists\", function () {\r",
                      "    var jsonData = pm.response.json();\r",
                      "    pm.expect(jsonData.token).to.exist;\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Token is not empty\", function () {\r",
                      "    var jsonData = pm.response.json();\r",
                      "    pm.expect(jsonData.token).to.not.be.empty;\r",
                      "});\r",
                      "\r",
                      "var jsonData = pm.response.json();\r",
                      "pm.environment.set(\"token\", jsonData.token);\r",
                      "\r",
                      "pm.test(\"Token variable stored\", function () {\r",
                      "    pm.expect(pm.collectionVariables.get(\"token\")).to.exist;\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
